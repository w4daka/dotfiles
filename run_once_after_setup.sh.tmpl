#!/usr/bin/env bash
set -euo pipefail

echo "=================================="
echo "chezmoi bootstrap start"
echo "=================================="

# --------------------------------------------------
# OS detection
# --------------------------------------------------

if command -v apt >/dev/null 2>&1; then
    OS="debian"
elif command -v pacman >/dev/null 2>&1; then
    OS="arch"
else
    OS="unknown"
fi

echo "Detected OS: $OS"

# --------------------------------------------------
# minimal packages
# --------------------------------------------------

if [ "$OS" = "debian" ]; then
    echo "Installing minimal packages (apt)"

    sudo apt update

    sudo apt install -y \
        curl \
        git \
        build-essential \
        ca-certificates

elif [ "$OS" = "arch" ]; then
    echo "Installing minimal packages (pacman)"

    sudo pacman -Sy --noconfirm

    sudo pacman -S --needed --noconfirm \
        curl \
        git \
        base-devel \
        ca-certificates

else
    echo "Unsupported OS"
    exit 1
fi


# --------------------------------------------------
# install nix
# --------------------------------------------------

if ! command -v nix >/dev/null 2>&1; then
    echo "Installing Nix"

    curl --proto '=https' --tlsv1.2 -sSf -L https://install.determinate.systems/nix | sh -s -- install
fi


# --------------------------------------------------
# load nix environment
# --------------------------------------------------

if [ -f "$HOME/.nix-profile/etc/profile.d/nix.sh" ]; then
    . "$HOME/.nix-profile/etc/profile.d/nix.sh"
fi


# --------------------------------------------------
# enable flakes
# --------------------------------------------------

mkdir -p ~/.config/nix

if ! grep -q "flakes" ~/.config/nix/nix.conf 2>/dev/null; then
cat <<EOF >> ~/.config/nix/nix.conf
experimental-features = nix-command flakes
EOF
fi


# --------------------------------------------------
# apply flake home-manager
# --------------------------------------------------

DOTFILES="$HOME/.local/share/chezmoi"

echo "Applying flake configuration"

nix run home-manager/master -- switch --flake .


# --------------------------------------------------
# finish
# --------------------------------------------------

echo "=================================="
echo "Bootstrap finished"
echo "Log out and log in again"
echo "=================================="
